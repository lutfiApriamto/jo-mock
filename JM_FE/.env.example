# URL backend API — digunakan untuk panggilan REST (auth, project, endpoint, dsb.)
# Development : http://localhost:3000/api
# Production  : https://your-backend.vercel.app/api
VITE_API_URL=http://localhost:3000/api

# URL frontend itu sendiri — digunakan untuk membentuk mock URL yang dipakai user
# Mock call mengalir: User App → FE URL/mock/... → (proxy) → BE
# Development : http://localhost:5173
# Production  : https://your-frontend.vercel.app  (set di Vercel dashboard, bukan di file ini)
VITE_APP_URL=http://localhost:5173

# ─── Hanya untuk Vercel (set di Vercel dashboard, BUKAN di file ini) ────────────
# BACKEND_BASE_URL = https://your-backend.vercel.app
#   → Dipakai oleh vercel.json (FE) untuk mem-proxy /mock/* ke BE
#   → Bukan env var browser (tidak butuh prefix VITE_)
#   → Set di: Vercel dashboard → Project FE → Settings → Environment Variables
