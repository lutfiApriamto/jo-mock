# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string — gunakan MongoDB Atlas untuk production
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
URI=mongodb+srv://username:password@cluster.mongodb.net/jo-mock?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secret key untuk signing JWT access token
# Gunakan string acak minimal 32 karakter — JANGAN commit nilai production ke git
# Generate contoh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY=ganti_dengan_random_string_minimal_32_karakter_yang_sangat_aman

# ─── Server ────────────────────────────────────────────────────────────────────
# Port untuk dev server lokal (default: 5000)
# Tidak digunakan di Vercel — Vercel menentukan port sendiri
PORT=5000

# Environment: 'development' atau 'production'
# Mempengaruhi: cookie.secure (true di production), cookie.sameSite (None di production)
NODE_ENV=development

# URL frontend — dipakai untuk:
#   1. CORS whitelist
#   2. Link dalam email (accept/decline invitation, reset password, dashboard)
# Development: http://localhost:5173
# Production : https://your-frontend-domain.vercel.app
CLIENT_URL=http://localhost:5173

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Akun Gmail yang digunakan sebagai pengirim email platform
EMAIL_USER=youremail@gmail.com

# Gmail App Password — BUKAN password akun Google biasa
# Cara mendapatkan: Google Account → Security → 2-Step Verification → App Passwords
# Format: 16 karakter tanpa spasi (contoh: abcd efgh ijkl mnop → abcdefghijklmnop)
EMAIL_PASS=your_gmail_app_password_16_chars

# ─── Superadmin Initial Credentials ────────────────────────────────────────────
# Kredensial superadmin pertama yang dibuat via POST /api/auth/admin/register
# Route ini hanya bisa dipanggil SEKALI — akan error jika superadmin sudah ada
# Setelah inisialisasi, variabel ini tidak lagi digunakan untuk autentikasi
EMAIL_ADMIN=admin@yourdomain.com
EMAIL_ADMIN_PASS=superadmin_password_minimal_8_karakter
